    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
